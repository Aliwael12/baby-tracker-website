generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_URL")
}

model ActivityLog {
  id              Int       @id @default(autoincrement())
  type            String
  side            String?
  diaperStatus    String?
  startTime       DateTime
  endTime         DateTime?
  durationMinutes Float?
  comments        String?
  enteredByName   String
  createdAt       DateTime  @default(now())
}
